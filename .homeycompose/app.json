{
  "id": "app.l4m.flowconverter",
  "name": {
    "en": "Flow Converter"
  },
  "description": {
    "en": "Convert and update device references in Homey flows and advanced flows."
  },
  "version": "1.0.0",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "author": "late4marshmellow",
  "contributors": {
    "developers": [
      {
        "name": "Martijn Poppen"
      }
    ]
  },
  "category": [
    "tools"
  ],
  "permissions": [
    "homey:manager:api"
  ],
  "main": "app.js",
  "compatibility": ">=5.0.0",
  "icon": "assets/icon.svg",
  "api": {
    "getDevices": {
      "method": "GET",
      "path": "/devices/"
    },
    "runConverter": {
      "method": "POST",
      "path": "/run/"
    },
    "getOrphanedDevices": {
      "method": "GET",
      "path": "/orphaned-devices/"
    },
    "getFlowList": {
      "method": "GET",
      "path": "/flow-list/"
    },
    "getFlowListNoSlash": {
      "method": "GET",
      "path": "/flow-list"
    },
    "getCapabilityList": {
      "method": "GET",
      "path": "/capability-list/"
    },
    "getCapabilityListNoSlash": {
      "method": "GET",
      "path": "/capability-list"
    },
    "getCapabilityDebug": {
      "method": "GET",
      "path": "/capability-debug/"
    },
    "getCapabilityDebugNoSlash": {
      "method": "GET",
      "path": "/capability-debug"
    }
  }
}