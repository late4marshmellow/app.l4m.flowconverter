{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "ignorePatterns": [
    "node_modules/",
    ".homeybuild/"
  ],
  "rules": {

    // Strict mode
    "strict": ["error", "global"],

    // Variables 
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": ["error", { "vars": "all", "args": "none", "ignoreRestSiblings": true }],
    "no-shadow": "off",
    "no-use-before-define": ["error", { "functions": false, "classes": true, "variables": true }],

    // Async / Promises
    "no-await-in-loop": "off",
    "no-return-await": "error",
    "prefer-promise-reject-errors": "error",

    // Classes
    "class-methods-use-this": "off",
    "lines-between-class-members": ["error", "always", { "exceptAfterSingleLine": true }],

    // Formatting
    "indent": ["error", 2, { "SwitchCase": 1 }],
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "comma-dangle": ["error", "always-multiline"],
    "eol-last": ["error", "always"],
    "no-trailing-spaces": "error",
    "no-multiple-empty-lines": ["error", { "max": 1, "maxEOF": 0 }],
    "brace-style": ["error", "1tbs", { "allowSingleLine": false }],
    "curly": ["error", "all"],
    "space-before-blocks": "error",
    "keyword-spacing": ["error", { "before": true, "after": true }],
    "space-infix-ops": "error",
    "space-in-parens": ["error", "never"],
    "key-spacing": ["error", { "beforeColon": false, "afterColon": true }],
    "object-curly-spacing": ["error", "always"],
    "array-bracket-spacing": ["error", "never"],
    "space-before-function-paren": ["error", { "anonymous": "never", "named": "never", "asyncArrow": "always" }],
    "arrow-spacing": ["error", { "before": true, "after": true }],
    "arrow-body-style": "off",
    "max-len": ["warn", { "code": 150, "ignoreUrls": true, "ignoreStrings": false }],

    // Best practices
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-else-return": ["error", { "allowElseIf": false }],
    "no-param-reassign": "off",
    "no-underscore-dangle": "off",
    "no-plusplus": "off",
    "no-continue": "off",
    "no-bitwise": "off",
    "no-console": "warn",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "dot-notation": "off",
    "object-shorthand": ["error", "always", { "avoidQuotes": true }],
    "prefer-destructuring": [
      "error",
      {
        "VariableDeclarator": { "array": false, "object": true },
        "AssignmentExpression": { "array": false, "object": false }
      },
      { "enforceForRenamedProperties": false }
    ],
    "prefer-template": "error",
    "no-useless-concat": "error",

    // Restricted patterns
    "no-restricted-syntax": [
      "error",
      {
        "selector": "ForInStatement",
        "message": "for..in iterates over the entire prototype chain. Use Object.{keys,values,entries} instead."
      },
      {
        "selector": "LabeledStatement",
        "message": "Labels are a form of GOTO and make code confusing and hard to maintain."
      },
      {
        "selector": "WithStatement",
        "message": "`with` is disallowed in strict mode."
      }
    ],

    // Comments (strict)
    "spaced-comment": [
      "error",
      "always",
      {
        "line": { "markers": ["/", "!"] },
        "block": { "markers": ["!"], "balanced": true }
      }
    ],
    "multiline-comment-style": ["error", "starred-block"],
    "no-inline-comments": "error",
    "capitalized-comments": [
      "warn",
      "always",
      {
        "ignorePattern": "eslint|eslint-disable|istanbul|prettier|noinspection|type|ts-|c8",
        "ignoreConsecutiveComments": true,
        "ignoreInlineComments": false
      }
    ],
    "no-warning-comments": [
      "warn",
      { "terms": ["todo", "fixme", "hack", "xxx"], "location": "start" }
    ]
  }
}
